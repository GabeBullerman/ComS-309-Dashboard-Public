#!/bin/sh
# Maven Wrapper

BASEDIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASEDIR"}

if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  echo "ERROR: MAVEN_PROJECTBASEDIR is not set." >&2
  exit 1
fi

WRAPPER_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"
WRAPPER_PROPERTIES="$WRAPPER_DIR/maven-wrapper.properties"
WRAPPER_MAIN=org.apache.maven.wrapper.MavenWrapperMain

if [ ! -r "$WRAPPER_PROPERTIES" ]; then
  echo "ERROR: $WRAPPER_PROPERTIES not found." >&2
  exit 1
fi

if [ ! -r "$WRAPPER_JAR" ]; then
  echo "Downloading Maven wrapper..."
  wrapperUrl=$(grep -E '^wrapperUrl=' "$WRAPPER_PROPERTIES" | cut -d= -f2-)
  if [ -z "$wrapperUrl" ]; then
    echo "ERROR: wrapperUrl not set in $WRAPPER_PROPERTIES" >&2
    exit 1
  fi
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$WRAPPER_JAR" "$wrapperUrl" || exit 1
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$wrapperUrl" || exit 1
  else
    echo "ERROR: curl or wget required to download Maven wrapper" >&2
    exit 1
  fi
fi

JAVA_CMD=${JAVA_HOME:+"$JAVA_HOME/bin/java"}
JAVA_CMD=${JAVA_CMD:-java}

exec "$JAVA_CMD" -classpath "$WRAPPER_JAR" \
  -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" \
  ${MAVEN_OPTS} \
  "$WRAPPER_MAIN" "$@"
