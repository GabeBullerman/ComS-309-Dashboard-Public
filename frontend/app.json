{
  "expo": {
    "name": "Instructor Dashboard",
    "slug": "instructor-dashboard",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/Images/Iowa_State_Cyclones_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.gabebullerman1.instructordashboard",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gabebullerman1.instructordashboard"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "9cef021a-b4c7-45e7-b7a4-0d19cd95c969"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
